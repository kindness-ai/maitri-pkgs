# Maintainer: Kindness <hello@kindness.ai>

# shellcheck disable=SC2034,SC2154,SC2164

# The prebuilt maitri Vicinae extension bundle, shipped through the [maitri] channel
# so it lands in the offline ISO mirror. It installs to a system location;
# `maitri-refresh-vicinae-extension` copies it into the user's Vicinae extensions dir
# (Vicinae only loads extensions from ~/.local/share/vicinae/extensions).
pkgname=maitri-vicinae-extension
pkgver=0.6.1
pkgrel=1
pkgdesc="maitri control menu + keybindings extension for Vicinae"
arch=('any')
url="https://github.com/kindness-ai/vicinae-maitri"
license=('MIT')
depends=('vicinae')

_asset="maitri-vicinae-extension.tar.gz"
noextract=("$pkgname-$pkgver.tar.gz")
source=("$pkgname-$pkgver.tar.gz::${url}/releases/download/v${pkgver}/${_asset}")

# Matches maitri-vicinae-extension.tar.gz.sha256 from the vicinae-maitri v$pkgver release.
sha256sums=('60bac3f77eb57001077598be6cc4e40684c06dd2b418bd5c79f172ed70ab3814')

package() {
  local dest="$pkgdir/usr/share/maitri/vicinae-extension"
  install -d "$dest"
  # The release tarball unpacks directly to package.json + *.js + assets/ + icon.png.
  tar -xzf "$srcdir/$pkgname-$pkgver.tar.gz" -C "$dest"
}
