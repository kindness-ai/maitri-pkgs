# Contributor: Shiina Rikka <rikka@rikka.im>

_pkgbase=yt6801
pkgname=yt6801-dkms
pkgver=1.0.33
pkgrel=1
pkgdesc="Kernel module for Motorcomm YT6801 ethernet controller (DKMS)"
arch=('x86_64')
url="https://www.motor-comm.com/product/ethernet-control-chip"
license=('GPL-2.0-or-later')
depends=('dkms')
# The vendor download is a zip containing yt_nic_install.sh and the real source
# tarball (yt6801-<pkgver>.tar.gz, sources at its root). makepkg auto-extracts the
# zip; prepare() unpacks the inner tarball into src/ and applies the kernel-compat patch.
source=(${_pkgbase}-${pkgver}.zip::'https://www.motor-comm.com/Cn/Skippower/downloadFile.html?id=1817'
        'patch.diff')
sha256sums=('023d84095bf560f7d050fc4eba426eab4be622604d6181f604ef7e0e63456715'
            'SKIP')

prepare() {
  cd "${srcdir}"
  rm -rf src && mkdir src
  tar -zxf "${_pkgbase}-${pkgver}.tar.gz" -C src
  patch -p1 < patch.diff
}

package() {
  install -dm755 "${pkgdir}/usr/src/${_pkgbase}-${pkgver}"
  install -m644 "${srcdir}"/src/*.c       "${pkgdir}/usr/src/${_pkgbase}-${pkgver}/"
  install -m644 "${srcdir}"/src/*.h       "${pkgdir}/usr/src/${_pkgbase}-${pkgver}/"
  install -m644 "${srcdir}/src/Makefile"  "${pkgdir}/usr/src/${_pkgbase}-${pkgver}/"
  install -m644 "${srcdir}/src/dkms.conf" "${pkgdir}/usr/src/${_pkgbase}-${pkgver}/"
  install -m644 "${srcdir}/src/motorcomm" "${pkgdir}/usr/src/${_pkgbase}-${pkgver}/"
}
